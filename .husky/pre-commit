#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# 质量检查三步曲：lint → typecheck → test
echo "🔍 Running quality checks..."

# 1. ESLint 检查
echo "📋 1/3: Running ESLint..."
npx eslint src --ext .ts
if [ $? -ne 0 ]; then
  echo "❌ ESLint failed!"
  exit 1
fi
echo "✅ ESLint passed"

# 2. TypeScript 编译检查
echo "📋 2/3: Running TypeScript compiler..."
npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo "❌ TypeScript compilation failed!"
  exit 1
fi
echo "✅ TypeScript passed"

# 3. 单元测试（只运行与变更文件相关的测试）
echo "📋 3/3: Running tests..."
npx lint-staged
if [ $? -ne 0 ]; then
  echo "❌ Tests failed!"
  exit 1
fi
echo "✅ Tests passed"

echo "🎉 All quality checks passed!"
